📄 lib/main.dart
import 'package:flutter/material.dart';
import 'package:hive_flutter/hive_flutter.dart';
import 'package:provider/provider.dart';
import 'package:lottie/lottie.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await Hive.initFlutter();
  await Hive.openBox('flower_joy');
  runApp(const FlowerJoyApp());
}

class FlowerJoyApp extends StatelessWidget {
  const FlowerJoyApp({super.key});
  @override
  Widget build(BuildContext context) {
    return ChangeNotifierProvider(
      create: (_) => AppState(),
      child: MaterialApp(
        title: 'Цветочек Радости',
        theme: ThemeData(brightness: Brightness.light, primarySwatch: Colors.teal, scaffoldBackgroundColor: const Color(0xFFF8F4EC), useMaterial3: true),
        home: const HomeScreen(),
        debugShowCheckedModeBanner: false,
      ),
    );
  }
}

class AppState extends ChangeNotifier {
  final _box = Hive.box('flower_joy');
  int level = 1;
  String mood = '😊';
  double volume = 0.7;
  bool isPlaying = false;
  AppState() {
    level = _box.get('level', defaultValue: 1) as int;
    mood = _box.get('mood', defaultValue: '😊') as String;
    volume = _box.get('volume', defaultValue: 0.7) as double;
  }
  void setLevel(int v) { level = v; _box.put('level', level); notifyListeners(); }
  void setMood(String v) { mood = v; _box.put('mood', mood); notifyListeners(); }
  void setVolume(double v) { volume = v; _box.put('volume', volume); notifyListeners(); }
  void togglePlay() { isPlaying = !isPlaying; notifyListeners(); }
}

class HomeScreen extends StatelessWidget {
  const HomeScreen({super.key});
  @override
  Widget build(BuildContext context) {
    final state = context.watch<AppState>();
    return Scaffold(
      appBar: AppBar(title: const Text('Цветочек Радости'), centerTitle: true),
      body: SafeArea(
        child: Padding(
          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 10),
          child: Column(
            children: [
              Row(mainAxisAlignment: MainAxisAlignment.spaceBetween, children: [
                Text('Уровень: ${state.level}', style: const TextStyle(fontSize: 16, fontWeight: FontWeight.w600)),
                Text('Настроение: ${state.mood}', style: const TextStyle(fontSize: 16)),
              ]),
              const SizedBox(height: 20),
              Expanded(flex: 2, child: Center(child: Lottie.asset('assets/lottie/flower.json', width: 180, height: 180, errorBuilder: (_, __, ___) => Container(width: 160, height: 160, decoration: BoxDecoration(shape: BoxShape.circle, color: Colors.pink.shade50), child: Icon(Icons.local_florist, size: 70, color: Colors.pink.shade300))))),
              const SizedBox(height: 15),
              Wrap(spacing: 8, runSpacing: 8, alignment: WrapAlignment.center, children: ['😊','😢','😴','🤯','🥰','🌿'].map((e) => ElevatedButton(onPressed: () => state.setMood(e), style: ElevatedButton.styleFrom(backgroundColor: state.mood == e ? Colors.teal : Colors.grey.shade200, foregroundColor: Colors.black87), child: Text(e, style: const TextStyle(fontSize: 22)))).toList()),
              const SizedBox(height: 15),
              Row(children: [
                IconButton(icon: Icon(state.isPlaying ? Icons.pause_circle : Icons.play_circle), onPressed: state.togglePlay),
                Expanded(child: Slider(value: state.volume, onChanged: state.setVolume, min: 0, max: 1)),
              ]),
              const SizedBox(height: 15),
              Row(mainAxisAlignment: MainAxisAlignment.spaceEvenly, children: [
                ElevatedButton.icon(onPressed: state.level < 1000 ? () => state.setLevel(state.level + 1) : null, icon: const Icon(Icons.arrow_upward), label: const Text('След. уровень')),
                ElevatedButton.icon(onPressed: () => _requestMicPermission(), icon: const Icon(Icons.mic), label: const Text('Дыхание')),
              ]),
              const SizedBox(height: 20),
            ],
          ),
        ),
      ),
    );
  }
  void _requestMicPermission() async {}
}

